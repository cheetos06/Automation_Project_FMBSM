GMAIL_ADDRESS=fmbsm.ai@gmail.com
GMAIL_APP_PASSWORD=replace-with-gmail-app-password
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
MONITORED_MAILBOXES=INBOX,[Gmail]/Spam
INBOX_MAILBOX=INBOX
MOVE_SPAM_TO_INBOX=true

SUBJECT_PREFIX=[optimda-extract-dates]
FS_SUBJECT_PREFIX=[fs-review]
EFFECTIF_SUBJECT_PREFIX=[optimda-effectif]
BALANCE_SUBJECT_PREFIX=[balance-cleaner]
FS_DEFAULT_YEAR=2025
# Exact addresses and exact domains only. Configure at least one; the worker fails closed.
AUTHORIZED_JOB_SENDERS=approved.person@example.com
AUTHORIZED_JOB_SENDER_DOMAINS=forvismazars.com,mazars.fr
POLL_INTERVAL_SECONDS=3
LOG_LEVEL=INFO

BOT_DATA_DIR=/opt/fmbsm-automation/data/mail
COPILOT_DATA_DIR=/opt/fmbsm-automation/data/copilot
COPILOT_REGISTRY_DB=/opt/fmbsm-automation/data/copilot/registry.sqlite3
JOB_STATUS_DIR=/opt/fmbsm-automation/data/mail/state/job-status

# Generated automatically on the server if absent. Never commit the real value.
COPILOT_UPLOAD_KEY=replace-with-a-random-value-of-at-least-32-characters
# Comma-separated Microsoft tenant IDs allowed to contribute real Copilot sessions.
COPILOT_ALLOWED_TENANT_IDS=replace-with-approved-tenant-guid
COPILOT_MAX_ACCOUNTS=20
TOKEN_API_HOST=0.0.0.0
TOKEN_API_PORT=443
TOKEN_API_CERT_FILE=/opt/fmbsm-automation/data/tls/server.crt
TOKEN_API_KEY_FILE=/opt/fmbsm-automation/data/tls/server.key
TOKEN_API_REQUESTS_PER_MINUTE=12
TOKEN_CLIENT_ARTIFACT_DIR=/srv/fmbsm-artifacts/upload/token-client
TOKEN_CLIENT_DOWNLOADS_PER_HOUR=120

MAX_ATTACHMENT_BYTES=104857600
MAX_ZIP_EXTRACTED_BYTES=524288000
MAX_ZIP_FILES=1000
MAX_ARCHIVE_DEPTH=5
MAX_MESSAGES_PER_CYCLE=10
MAX_QUEUED_JOBS=50
MIN_FREE_DISK_BYTES=2147483648
QUEUE_RETRY_DELAY_SECONDS=30
QUEUE_DEFAULT_FS_SECONDS=900
QUEUE_DEFAULT_EFFECTIF_SECONDS=900
QUEUE_DEFAULT_SIGNATURE_SECONDS=300
QUEUE_DEFAULT_BALANCE_SECONDS=900
SEND_RETRY_NOTIFICATIONS=true
MAX_OUTBOUND_EMAILS_PER_HOUR=40
MAX_OUTBOUND_EMAILS_PER_DAY=200
MAX_PROCESSING_ATTEMPTS=3
PROCESSING_LOCK_SECONDS=14400
MARK_FAILED_AS_READ=true
EXTRACTION_TIMEOUT_SECONDS=300
FS_REVIEW_TIMEOUT_SECONDS=10800
EFFECTIF_TIMEOUT_SECONDS=21600
BALANCE_TIMEOUT_SECONDS=21600
MAX_RESULT_ATTACHMENT_BYTES=20971520
IMAP_TIMEOUT_SECONDS=30
SMTP_TIMEOUT_SECONDS=60
